{
  "name": "sf-territory-plugin",
  "version": "1.0.1",
  "description": "Salesforce CLI plugin to automate enabling Lead support in Enterprise Territory Management",
  "author": "Boris Thomas",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/BoboJD/sf-territory-plugin.git"
  },
  "bugs": {
    "url": "https://github.com/BoboJD/sf-territory-plugin/issues"
  },
  "homepage": "https://github.com/BoboJD/sf-territory-plugin#readme",
  "files": [
    "/lib",
    "/messages"
  ],
  "type": "module",
  "main": "lib/index.js",
  "exports": "./lib/index.js",
  "types": "lib/index.d.ts",
  "oclif": {
    "bin": "sf",
    "dirname": "sf",
    "commands": "./lib/commands",
    "hooks": {},
    "plugins": [],
    "devPlugins": []
  },
  "scripts": {
    "build": "tsc",
    "clean": "node -e \"require('fs').rmSync('lib', { recursive: true, force: true })\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint \"src/**/*.ts\"",
    "lint:fix": "eslint \"src/**/*.ts\" --fix",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "postinstall": "playwright install chromium",
    "prepack": "npm run build",
    "dev": "tsc --watch"
  },
  "dependencies": {
    "@salesforce/core": "^8.5.1",
    "@salesforce/sf-plugins-core": "^11.0.0",
    "playwright": "^1.40.0",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@eslint/js": "^8.52.0",
    "@types/jest": "^29.5.8",
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^8.59.2",
    "@typescript-eslint/parser": "^8.59.2",
    "eslint": "^8.52.0",
    "jest": "^29.7.0",
    "prettier": "^3.1.0",
    "ts-jest": "^29.1.1",
    "typescript": "^5.3.2"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "salesforce",
    "cli",
    "plugin",
    "territory",
    "lead"
  ]
}
